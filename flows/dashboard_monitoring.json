  {
    "id": "dashboard_data_processor",
    "type": "function",
    "name": "Dashboard Data Processor",
    "func": "// Process consolidated device data for dashboard display\nconst devices = msg.payload.devices || {};\nconst huawei = devices['Huawei SmartLogger 3000A'] || {};\nconst gc600 = devices['SICES GC600'] || {};\nconst mc200 = devices['SICES MC200'] || {};\n\n// Prepare power flow data\nconst powerFlowData = {\n  pv_power: parseFloat(huawei.active_power) || 0,\n  genset_power: parseFloat(gc600.active_power) || 0,\n  grid_power: parseFloat(mc200.active_power_total) || 0,\n  total_load: (parseFloat(huawei.active_power) || 0) + (parseFloat(gc600.active_power) || 0) - (parseFloat(mc200.active_power_total) || 0),\n  is_importing: mc200.is_importing || false,\n  is_exporting: mc200.is_exporting || false,\n  timestamp: new Date().toISOString()\n};\n\n// Send power flow data\nnode.send([{\n  topic: 'dashboard/power_flow',\n  payload: powerFlowData\n}, null, null, null, null, null, null, null]);\n\n// Send individual device data\nif (huawei.active_power !== undefined) {\n  node.send([null, {\n    topic: 'dashboard/huawei_power',\n    payload: parseFloat(huawei.active_power) || 0\n  }, null, null, null, null, null, null]);\n  \n  node.send([null, null, {\n    topic: 'dashboard/huawei_voltage',\n    payload: parseFloat(huawei.phase_a_voltage) || 0\n  }, null, null, null, null, null]);\n}\n\nif (gc600.active_power !== undefined) {\n  node.send([null, null, null, {\n    topic: 'dashboard/gc600_power',\n    payload: parseFloat(gc600.active_power) || 0\n  }, null, null, null, null]);\n  \n  const gensetStatus = parseFloat(gc600.active_power) > 0 ? 'running' : 'stopped';\n  node.send([null, null, null, null, {\n    topic: 'dashboard/gc600_status',\n    payload: gensetStatus\n  }, null, null, null]);\n}\n\nif (mc200.active_power_total !== undefined) {\n  node.send([null, null, null, null, null, {\n    topic: 'dashboard/mc200_power',\n    payload: parseFloat(mc200.active_power_total) || 0\n  }, null, null]);\n  \n  // Grid status indicator\n  let gridStatus = 'connected';\n  if (mc200.is_exporting) gridStatus = 'exporting';\n  if (mc200.grid_status === 0) gridStatus = 'disconnected';\n  \n  node.send([null, null, null, null, null, null, {\n    topic: 'dashboard/grid_status',\n    payload: gridStatus\n  }, null]);\n  \n  // Export status\n  const exportStatus = mc200.is_exporting ? 'active' : 'standby';\n  node.send([null, null, null, null, null, null, null, {\n    topic: 'dashboard/export_status',\n    payload: exportStatus\n  }]);\n}\n\nreturn null;",
    "outputs": 8,
    "noerr": 0,
    "x": 200,
    "y": 60,
    "z": "dashboard_flow",
    "wires": [
      ["power_flow_template"],
      ["huawei_power_display"],
      ["huawei_voltage_gauge"],
      ["gc600_power_display"],
      ["gc600_status_led"],
      ["mc200_grid_power"],
      ["grid_status_indicator"],
      ["export_status_indicator"]
    ]
  },
  {
    "id": "mgcb_command_handler",
    "type": "function",
    "name": "MGCB Command Handler",
    "func": "// Handle MGCB control command\nconst command = {\n  device: 'SICES MC200',\n  action: 'mgcb_control',\n  value: msg.payload,\n  timestamp: new Date().toISOString(),\n  source: 'manual_dashboard'\n};\n\nmsg.payload = command;\nmsg.topic = 'control/manual/mgcb';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 400,
    "y": 500,
    "z": "dashboard_flow",
    "wires": [
      ["manual_command_processor"]
    ]
  },
  {
    "id": "genset_command_handler",
    "type": "function",
    "name": "Genset Command Handler",
    "func": "// Handle genset start/stop command\nconst command = {\n  device: 'SICES GC600',\n  action: msg.payload === 1 ? 'start_genset' : 'stop_genset',\n  value: msg.payload,\n  timestamp: new Date().toISOString(),\n  source: 'manual_dashboard'\n};\n\nmsg.payload = command;\nmsg.topic = 'control/manual/genset';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 600,
    "y": 500,
    "z": "dashboard_flow",
    "wires": [
      ["manual_command_processor"]
    ]
  },
  {
    "id": "export_command_handler",
    "type": "function",
    "name": "Export Command Handler",
    "func": "// Handle export enable/disable command\nconst command = {\n  device: 'SICES MC200',\n  action: 'export_enable',\n  value: msg.payload,\n  timestamp: new Date().toISOString(),\n  source: 'manual_dashboard'\n};\n\nmsg.payload = command;\nmsg.topic = 'control/manual/export';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 800,
    "y": 500,
    "z": "dashboard_flow",
    "wires": [
      ["manual_command_processor"]
    ]
  },
  {
    "id": "pv_limit_command_handler",
    "type": "function",
    "name": "PV Limit Command Handler",
    "func": "// Handle PV power limit command\nconst command = {\n  device: 'Huawei SmartLogger 3000A',\n  action: 'set_power_limit',\n  value: msg.payload,\n  timestamp: new Date().toISOString(),\n  source: 'manual_dashboard'\n};\n\nmsg.payload = command;\nmsg.topic = 'control/manual/pv_limit';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 400,
    "y": 540,
    "z": "dashboard_flow",
    "wires": [
      ["manual_command_processor"]
    ]
  },
  {
    "id": "genset_setpoint_command_handler",
    "type": "function",
    "name": "Genset Setpoint Handler",
    "func": "// Handle genset power setpoint command\nconst command = {\n  device: 'SICES GC600',\n  action: 'set_power_setpoint',\n  value: msg.payload,\n  timestamp: new Date().toISOString(),\n  source: 'manual_dashboard'\n};\n\nmsg.payload = command;\nmsg.topic = 'control/manual/genset_setpoint';\nreturn msg;",
