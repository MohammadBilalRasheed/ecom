    "name": "Manual Command Processor",
    "func": "// Process manual commands from dashboard\nconst command = msg.payload;\n\n// Log manual command\nnode.log(`Manual command: ${command.action} on ${command.device} with value ${command.value}`);\n\n// Override automatic control temporarily\nconst manualOverride = global.get('manualOverride') || {};\nmanualOverride[command.device] = {\n  active: true,\n  timestamp: command.timestamp,\n  expires: Date.now() + 300000 // 5 minutes\n};\nglobal.set('manualOverride', manualOverride);\n\n// Forward to control logic\nmsg.topic = 'control/manual';\nreturn msg;",
