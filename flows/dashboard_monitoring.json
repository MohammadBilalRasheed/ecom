  {
    "id": "power_flow_template",
    "type": "ui-template",
    "name": "Power Flow Visualization",
    "group": "ui_group_power_flow",
    "order": 1,
    "width": "6",
    "height": "3",
    "format": "<div class=\"power-flow-container\">\n  <svg width=\"100%\" height=\"200\" viewBox=\"0 0 400 200\">\n    <!-- PV Array -->\n    <rect x=\"20\" y=\"20\" width=\"60\" height=\"40\" fill=\"#4CAF50\" stroke=\"#333\" stroke-width=\"2\"/>\n    <text x=\"50\" y=\"45\" text-anchor=\"middle\" fill=\"white\" font-size=\"12\">PV</text>\n    <text x=\"50\" y=\"75\" text-anchor=\"middle\" fill=\"#333\" font-size=\"10\">{{msg.payload.pv_power}} kW</text>\n    \n    <!-- Genset -->\n    <rect x=\"20\" y=\"140\" width=\"60\" height=\"40\" fill=\"#FF9800\" stroke=\"#333\" stroke-width=\"2\"/>\n    <text x=\"50\" y=\"165\" text-anchor=\"middle\" fill=\"white\" font-size=\"12\">GEN</text>\n    <text x=\"50\" y=\"195\" text-anchor=\"middle\" fill=\"#333\" font-size=\"10\">{{msg.payload.genset_power}} kW</text>\n    \n    <!-- Load -->\n    <rect x=\"170\" y=\"80\" width=\"60\" height=\"40\" fill=\"#2196F3\" stroke=\"#333\" stroke-width=\"2\"/>\n    <text x=\"200\" y=\"105\" text-anchor=\"middle\" fill=\"white\" font-size=\"12\">LOAD</text>\n    <text x=\"200\" y=\"135\" text-anchor=\"middle\" fill=\"#333\" font-size=\"10\">{{msg.payload.total_load}} kW</text>\n    \n    <!-- Grid -->\n    <rect x=\"320\" y=\"80\" width=\"60\" height=\"40\" fill=\"#9C27B0\" stroke=\"#333\" stroke-width=\"2\"/>\n    <text x=\"350\" y=\"105\" text-anchor=\"middle\" fill=\"white\" font-size=\"12\">GRID</text>\n    <text x=\"350\" y=\"135\" text-anchor=\"middle\" fill=\"#333\" font-size=\"10\">{{msg.payload.grid_power}} kW</text>\n    \n    <!-- Power Flow Lines -->\n    <line x1=\"80\" y1=\"40\" x2=\"170\" y2=\"100\" stroke=\"#4CAF50\" stroke-width=\"3\" marker-end=\"url(#arrowhead)\"/>\n    <line x1=\"80\" y1=\"160\" x2=\"170\" y2=\"100\" stroke=\"#FF9800\" stroke-width=\"3\" marker-end=\"url(#arrowhead)\"/>\n    <line x1=\"230\" y1=\"100\" x2=\"320\" y2=\"100\" stroke=\"#2196F3\" stroke-width=\"3\" marker-end=\"url(#arrowhead)\"/>\n    \n    <!-- Arrow Marker -->\n    <defs>\n      <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\" refX=\"10\" refY=\"3.5\" orient=\"auto\">\n        <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#333\"/>\n      </marker>\n    </defs>\n  </svg>\n</div>\n\n<style>\n.power-flow-container {\n  background: linear-gradient(135deg, #1e1e1e 0%, #2d2d2d 100%);\n  border-radius: 8px;\n  padding: 10px;\n  color: white;\n}\n</style>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 200,
    "y": 60,
    "z": "dashboard_flow",
    "wires": []
  },
