    {
        "id": "history-formatter",
        "type": "function",
        "z": "ui-tab",
        "name": "History Data Formatter",
        "func": "// Format data for historical chart\nconst pvData = global.get('pv_data') || {};\nconst gensetData = global.get('genset_data') || {};\nconst gridData = global.get('power_meter_data') || {};\nconst systemState = global.get('system_state') || {};\n\nconst timestamp = new Date();\n\n// Create data points for chart\nconst messages = [];\n\n// PV Power\nmessages.push({\n    topic: 'history',\n    payload: {\n        series: ['PV Power'],\n        data: [[pvData.ac_power || 0]],\n        labels: [timestamp]\n    }\n});\n\n// Genset Power\nmessages.push({\n    topic: 'history',\n    payload: {\n        series: ['Genset Power'],\n        data: [[gensetData.ac_power || 0]],\n        labels: [timestamp]\n    }\n});\n\n// Grid Power\nmessages.push({\n    topic: 'history',\n    payload: {\n        series: ['Grid Power'],\n        data: [[gridData.total_active_power || 0]],\n        labels: [timestamp]\n    }\n});\n\n// Load Power\nmessages.push({\n    topic: 'history',\n    payload: {\n        series: ['Load Power'],\n        data: [[systemState.load_power || 0]],\n        labels: [timestamp]\n    }\n});\n\nreturn [messages];",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 350,
        "y": 540,
        "wires": [
            ["historical-data-chart"]
        ]
    },
    {
        "id": "alerts-list",
        "type": "ui_template",
        "z": "ui-tab",
        "group": "alerts-detail-group",
        "name": "Active Alerts List",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div ng-init=\"init()\">\n  <h3>Active Alerts</h3>\n  <div ng-if=\"alerts.length === 0\" style=\"color: #00b500; font-weight: bold;\">\n    ✅ No active alerts\n  </div>\n  <div ng-repeat=\"alert in alerts | orderBy:'-timestamp'\" \n       ng-class=\"{\n         'alert-critical': alert.type === 'critical',\n         'alert-warning': alert.type === 'warning',\n         'alert-info': alert.type === 'info'\n       }\"\n       style=\"margin: 5px 0; padding: 10px; border-radius: 5px; border-left: 4px solid;\">\n    <div style=\"font-weight: bold;\">{{alert.device.toUpperCase()}}</div>\n    <div>{{alert.message}}</div>\n    <div style=\"font-size: 11px; color: #666;\">{{alert.timestamp | date:'medium'}}</div>\n  </div>\n</div>\n\n<style>\n.alert-critical {\n  background-color: #ffe6e6;\n  border-left-color: #ff0000 !important;\n}\n.alert-warning {\n  background-color: #fff3cd;\n  border-left-color: #ffc107 !important;\n}\n.alert-info {\n  background-color: #e7f3ff;\n  border-left-color: #17a2b8 !important;\n}\n</style>\n\n<script>\n(function(scope) {\n  scope.alerts = [];\n  \n  scope.init = function() {\n    // Initialize alerts array\n    scope.alerts = [];\n  };\n  \n  scope.$watch('msg', function(msg) {\n    if (msg && msg.topic === 'alerts/list') {\n      scope.alerts = msg.payload || [];\n    }\n  });\n})(scope);\n</script>",
