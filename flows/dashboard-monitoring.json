    {
        "id": "alerts-formatter",
        "type": "function",
        "z": "ui-tab",
        "name": "Alerts Formatter",
        "func": "// Get active alerts and format for display\nconst activeAlerts = context.get('active_alerts') || [];\n\n// Clean up old alerts (older than 24 hours)\nconst now = new Date();\nconst cleanedAlerts = activeAlerts.filter(alert => {\n    const alertTime = new Date(alert.timestamp);\n    const hoursOld = (now - alertTime) / (1000 * 60 * 60);\n    return hoursOld < 24;\n});\n\n// Update cleaned alerts\ncontext.set('active_alerts', cleanedAlerts);\n\nmsg.topic = 'alerts/list';\nmsg.payload = cleanedAlerts;\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 330,
        "y": 600,
        "wires": [
            ["alerts-list"]
        ]
    },
