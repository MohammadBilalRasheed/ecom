    {
        "id": "power-flow-diagram",
        "type": "ui_template",
        "z": "ui-tab",
        "group": "powerflow-group",
        "name": "Power Flow Diagram",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div id=\"powerflow\" style=\"width: 100%; height: 400px;\">\n  <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 300\">\n    <!-- PV Panel -->\n    <rect x=\"50\" y=\"50\" width=\"80\" height=\"40\" fill=\"#FFD700\" stroke=\"#000\" stroke-width=\"2\"/>\n    <text x=\"90\" y=\"75\" text-anchor=\"middle\" font-size=\"12\">PV</text>\n    <text x=\"90\" y=\"105\" text-anchor=\"middle\" font-size=\"10\" id=\"pv-power\">{{pvPower}}W</text>\n    \n    <!-- Genset -->\n    <rect x=\"50\" y=\"200\" width=\"80\" height=\"40\" fill=\"#FF6B6B\" stroke=\"#000\" stroke-width=\"2\"/>\n    <text x=\"90\" y=\"225\" text-anchor=\"middle\" font-size=\"12\">Genset</text>\n    <text x=\"90\" y=\"255\" text-anchor=\"middle\" font-size=\"10\" id=\"genset-power\">{{gensetPower}}W</text>\n    \n    <!-- Load -->\n    <rect x=\"450\" y=\"125\" width=\"80\" height=\"40\" fill=\"#4ECDC4\" stroke=\"#000\" stroke-width=\"2\"/>\n    <text x=\"490\" y=\"150\" text-anchor=\"middle\" font-size=\"12\">Load</text>\n    <text x=\"490\" y=\"180\" text-anchor=\"middle\" font-size=\"10\" id=\"load-power\">{{loadPower}}W</text>\n    \n    <!-- Grid -->\n    <rect x=\"250\" y=\"250\" width=\"80\" height=\"40\" fill=\"#45B7D1\" stroke=\"#000\" stroke-width=\"2\"/>\n    <text x=\"290\" y=\"275\" text-anchor=\"middle\" font-size=\"12\">Grid</text>\n    <text x=\"290\" y=\"305\" text-anchor=\"middle\" font-size=\"10\" id=\"grid-power\">{{gridPower}}W</text>\n    \n    <!-- Power Flow Lines -->\n    <!-- PV to Load -->\n    <line x1=\"130\" y1=\"70\" x2=\"450\" y2=\"145\" stroke=\"#00FF00\" stroke-width=\"3\" id=\"pv-line\"/>\n    <text x=\"290\" y=\"100\" text-anchor=\"middle\" font-size=\"10\" fill=\"#00FF00\">PV → Load</text>\n    \n    <!-- Genset to Load -->\n    <line x1=\"130\" y1=\"220\" x2=\"450\" y2=\"145\" stroke=\"#FF0000\" stroke-width=\"3\" id=\"genset-line\"/>\n    <text x=\"290\" y=\"190\" text-anchor=\"middle\" font-size=\"10\" fill=\"#FF0000\">Genset → Load</text>\n    \n    <!-- Grid Connection -->\n    <line x1=\"290\" y1=\"250\" x2=\"490\" y2=\"165\" stroke=\"#0000FF\" stroke-width=\"3\" id=\"grid-line\"/>\n    <text x=\"390\" y=\"210\" text-anchor=\"middle\" font-size=\"10\" fill=\"#0000FF\" id=\"grid-direction\">{{gridDirection}}</text>\n  </svg>\n</div>\n\n<script>\n(function(scope) {\n  scope.$watch('msg', function(msg) {\n    if (msg && msg.topic === 'powerflow/data') {\n      var data = msg.payload;\n      \n      // Update power values\n      document.getElementById('pv-power').textContent = data.pv + 'W';\n      document.getElementById('genset-power').textContent = data.genset + 'W';\n      document.getElementById('load-power').textContent = data.load + 'W';\n      document.getElementById('grid-power').textContent = Math.abs(data.grid) + 'W';\n      \n      // Update grid direction\n      var gridDirection = data.grid > 0 ? 'Grid → Load' : data.grid < 0 ? 'Load → Grid' : 'No Flow';\n      document.getElementById('grid-direction').textContent = gridDirection;\n      \n      // Update line thickness based on power flow\n      var pvLine = document.getElementById('pv-line');\n      var gensetLine = document.getElementById('genset-line');\n      var gridLine = document.getElementById('grid-line');\n      \n      pvLine.style.strokeWidth = Math.max(1, data.pv / 1000);\n      gensetLine.style.strokeWidth = Math.max(1, data.genset / 1000);\n      gridLine.style.strokeWidth = Math.max(1, Math.abs(data.grid) / 1000);\n      \n      // Update colors based on status\n      if (data.pv > 100) {\n        pvLine.style.stroke = '#00FF00';\n      } else {\n        pvLine.style.stroke = '#CCCCCC';\n      }\n      \n      if (data.genset > 100) {\n        gensetLine.style.stroke = '#FF0000';\n      } else {\n        gensetLine.style.stroke = '#CCCCCC';\n      }\n      \n      if (data.grid > 100) {\n        gridLine.style.stroke = '#0000FF'; // Import\n      } else if (data.grid < -100) {\n        gridLine.style.stroke = '#FF8C00'; // Export\n      } else {\n        gridLine.style.stroke = '#CCCCCC'; // No flow\n      }\n    }\n  });\n})(scope);\n</script>",
