[
    {
        "id": "ui-tab",
        "type": "tab",
        "label": "Dashboard & Monitoring",
        "disabled": false,
        "info": "User interface and monitoring dashboard for real-time system visualization.",
        "env": []
    },
    {
        "id": "dashboard-init",
        "type": "inject",
        "z": "ui-tab",
        "name": "Dashboard Init",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": "2",
        "topic": "",
        "payload": "initialize",
        "payloadType": "str",
        "x": 120,
        "y": 60,
        "wires": [
            ["dashboard-setup"]
        ]
    },
    {
        "id": "dashboard-setup",
        "type": "function",
        "z": "ui-tab",
        "name": "Dashboard Setup",
        "func": "// Initialize dashboard with default values\n\n// Set initial system state\nconst initialState = {\n    timestamp: new Date().toISOString(),\n    pv_power: 0,\n    genset_power: 0,\n    grid_power: 0,\n    load_power: 0,\n    system_mode: 'Initializing...',\n    grid_status: 'Unknown',\n    pv_status: 'Unknown',\n    genset_status: 'Unknown'\n};\n\n// Initialize dashboard topics\nconst messages = [];\n\n// Power displays\nmessages.push({topic: 'pv/power', payload: 0});\nmessages.push({topic: 'genset/power', payload: 0});\nmessages.push({topic: 'grid/power', payload: 0});\nmessages.push({topic: 'load/power', payload: 0});\n\n// Status displays\nmessages.push({topic: 'pv/status', payload: 'Offline'});\nmessages.push({topic: 'genset/status', payload: 'Stopped'});\nmessages.push({topic: 'grid/status', payload: 'Unknown'});\nmessages.push({topic: 'system/mode', payload: 'Initializing'});\n\n// Efficiency and performance\nmessages.push({topic: 'pv/efficiency', payload: 0});\nmessages.push({topic: 'system/efficiency', payload: 0});\nmessages.push({topic: 'genset/fuel', payload: 100});\n\n// Energy counters\nmessages.push({topic: 'energy/pv_daily', payload: 0});\nmessages.push({topic: 'energy/genset_daily', payload: 0});\nmessages.push({topic: 'energy/grid_daily', payload: 0});\n\nnode.log('Dashboard initialized');\n\nreturn [messages];",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 60,
        "wires": [
            ["dashboard-router"]
        ]
    },
    {
        "id": "real-time-updater",
        "type": "inject",
        "z": "ui-tab",
        "name": "Real-time Update",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "2",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "update",
        "payloadType": "str",
        "x": 120,
        "y": 120,
        "wires": [
            ["data-aggregator"]
        ]
    },
    {
        "id": "data-aggregator",
        "type": "function",
        "z": "ui-tab",
        "name": "Data Aggregator",
        "func": "// Aggregate data from all systems for dashboard display\n\n// Get latest data from global context\nconst pvData = global.get('pv_data') || {};\nconst gensetData = global.get('genset_data') || {};\nconst gridData = global.get('power_meter_data') || {};\nconst systemState = global.get('system_state') || {};\nconst controlDecisions = global.get('control_decisions') || {};\nconst dailyStats = context.get('daily_stats') || {};\n\n// Check for emergency conditions\nconst emergency = global.get('emergency_stop') || false;\nconst manualOverride = global.get('manual_override') || false;\n\n// Calculate derived values\nconst totalGeneration = (pvData.ac_power || 0) + (gensetData.ac_power || 0);\nconst loadPower = totalGeneration + (gridData.total_active_power || 0);\nconst systemEfficiency = totalGeneration > 0 ? (loadPower / totalGeneration) * 100 : 0;\nconst pvContribution = totalGeneration > 0 ? ((pvData.ac_power || 0) / totalGeneration) * 100 : 0;\n\n// Determine system mode\nlet systemMode = 'Unknown';\nif (emergency) {\n    systemMode = '🚨 EMERGENCY STOP';\n} else if (manualOverride) {\n    systemMode = '👤 Manual Override';\n} else if (gridData.grid_connected) {\n    systemMode = '🔌 Grid Connected';\n} else {\n    systemMode = '🏝️ Off Grid';\n}\n\n// Create dashboard messages\nconst messages = [];\n\n// Power values\nmessages.push({topic: 'pv/power', payload: pvData.ac_power || 0});\nmessages.push({topic: 'genset/power', payload: gensetData.ac_power || 0});\nmessages.push({topic: 'grid/power', payload: gridData.total_active_power || 0});\nmessages.push({topic: 'load/power', payload: Math.round(loadPower)});\nmessages.push({topic: 'total/generation', payload: Math.round(totalGeneration)});\n\n// Status indicators\nmessages.push({topic: 'pv/status', payload: pvData.status === 3 ? '✅ Normal' : '⚠️ Fault'});\nmessages.push({topic: 'genset/status', payload: gensetData.running ? '🟢 Running' : '🔴 Stopped'});\nmessages.push({topic: 'grid/status', payload: gridData.grid_connected ? '🟢 Connected' : '🔴 Disconnected'});\nmessages.push({topic: 'system/mode', payload: systemMode});\n\n// Performance metrics\nmessages.push({topic: 'pv/efficiency', payload: Math.round(pvData.efficiency || 0)});\nmessages.push({topic: 'system/efficiency', payload: Math.round(systemEfficiency)});\nmessages.push({topic: 'pv/contribution', payload: Math.round(pvContribution)});\n\n// Environmental data\nmessages.push({topic: 'pv/temperature', payload: pvData.temperature || 0});\nmessages.push({topic: 'genset/temperature', payload: gensetData.engine_temp || 0});\nmessages.push({topic: 'genset/fuel', payload: gensetData.fuel_level || 0});\nmessages.push({topic: 'genset/oil_pressure', payload: gensetData.oil_pressure || 0});\n\n// Grid parameters\nmessages.push({topic: 'grid/voltage', payload: Math.round((gridData.l1_voltage + gridData.l2_voltage + gridData.l3_voltage) / 3) || 0});\nmessages.push({topic: 'grid/frequency', payload: gridData.frequency || 0});\nmessages.push({topic: 'grid/power_factor', payload: gridData.power_factor || 0});\n\n// Control status\nmessages.push({topic: 'control/pv_curtailment', payload: controlDecisions.pv_curtailment || 0});\nmessages.push({topic: 'control/genset_target', payload: controlDecisions.genset_target_power || 0});\nmessages.push({topic: 'control/export_limit', payload: controlDecisions.export_limit_active ? 'Active' : 'Inactive'});\n\n// Daily statistics\nmessages.push({topic: 'energy/pv_daily', payload: Math.round(dailyStats.total_pv_energy || 0)});\nmessages.push({topic: 'energy/genset_daily', payload: Math.round(dailyStats.total_genset_energy || 0)});\nmessages.push({topic: 'energy/fuel_consumed', payload: Math.round(dailyStats.estimated_fuel_consumed || 0)});\n\n// Power flow diagram data\nconst powerFlow = {\n    pv: pvData.ac_power || 0,\n    genset: gensetData.ac_power || 0,\n    load: loadPower,\n    grid: gridData.total_active_power || 0,\n    battery: 0 // Placeholder for future battery integration\n};\nmessages.push({topic: 'powerflow/data', payload: powerFlow});\n\n// Alerts summary\nconst activeAlerts = context.get('active_alerts') || [];\nconst criticalAlerts = activeAlerts.filter(alert => alert.type === 'critical').length;\nconst warningAlerts = activeAlerts.filter(alert => alert.type === 'warning').length;\n\nmessages.push({topic: 'alerts/critical', payload: criticalAlerts});\nmessages.push({topic: 'alerts/warning', payload: warningAlerts});\nmessages.push({topic: 'alerts/total', payload: activeAlerts.length});\n\nreturn [messages];",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 120,
        "wires": [
            ["dashboard-router"]
        ]
    },
